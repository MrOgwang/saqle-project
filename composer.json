{
     "name": "mrogwang/saqle-project",
     "type": "project",
     "description": "Starter application for the SaQle PHP framework",
     "license": "MIT",
     "prefer-stable": true,
     "require": {
         "php": "^8.4",
         "mrogwang/saqle": "^0.3.0"
     },
     "autoload": {
         "psr-4": {
             "App\\": ""
         }
     },
     "scripts": {
        "post-create-project-cmd": [
            "@composer dump-autoload",
            "@php saqle install"
        ]
    }
}
